{
    "name": "crumbls/subscriptions",
    "description": "A flexible plans and subscription management system for Laravel. Manage your SaaS plans, features, and subscriber usage with ease.",
    "type": "library",
    "keywords": [
        "plan",
        "laravel",
        "feature",
        "subscription",
        "saas",
        "recurring"
    ],
    "license": "MIT",
    "homepage": "https://github.com/Crumbls/subscriptions",
    "support": {
        "issues": "https://github.com/Crumbls/subscriptions/issues",
        "source": "https://github.com/Crumbls/subscriptions"
    },
    "authors": [
        {
            "name": "Crumbls",
            "homepage": "https://crumbls.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "spatie/eloquent-sortable": "^4.4",
        "spatie/laravel-sluggable": "^3.6",
        "spatie/laravel-translatable": "^6.8"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1",
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Crumbls\\Subscriptions\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Crumbls\\Subscriptions\\Tests\\": "tests"
        }
    },
  "scripts": {
    "lint": "pint",
    "refactor": "rector",
    "test:type-coverage": "pest --type-coverage --exactly=100",
    "test:typos": "peck",
    "test:lint": "pint --test",
    "test:unit": "pest --coverage --exactly=100",
    "test:types": "phpstan",
    "test:refactor": "rector --dry-run",
    "test": [
      "@test:lint",
      "@test:type-coverage",
      "@test:typos",
      "@test:unit",
      "@test:types",
      "@test:refactor"
    ]
  },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Crumbls\\Subscriptions\\SubscriptionsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
